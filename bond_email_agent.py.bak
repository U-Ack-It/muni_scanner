"""
Muni Bond Email Agent
=====================
Watches olivierboukli@gmail.com for dealer inventory emails (run sheets).
Parses CUSIP / yield / maturity / rating from unstructured dealer text using Claude.
Appends extracted bonds to data/incoming_bonds.csv for the scanner.

Dealers to contact (send "please add me to your muni inventory list"):
  Raymond James      — municipals@raymondjames.com
  Robert W. Baird    — fixed.income@rwbaird.com
  Piper Sandler      — munibonds@pipersandler.com
  Stifel             — muni@stifel.com
  Bernardi Securities— info@bernardisecurities.com  (muni specialist, small issues)
  HJ Sims            — munibonds@hjsims.com          (muni specialist)
  DA Davidson        — fixedincome@dadavidson.com

Gmail setup (one-time):
  Create a Gmail filter: from any dealer domain → apply label "bond-inventory"
  The agent watches that label — keeps it separate from GallerySense leads.

Usage:
    python3 bond_email_agent.py          # one scan
    python3 bond_email_agent.py --loop   # poll every 10 min
    python3 bond_email_agent.py --dry-run # parse but don't write CSV
"""

import base64
import csv
import json
import os
import pickle
import re
import sys
import time
from datetime import datetime, date

import requests
from pathlib import Path

from dotenv import load_dotenv
load_dotenv(Path(__file__).parent / ".env")

import anthropic
from googleapiclient.discovery import build

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

TOKEN_PATH   = Path("/home/u-ack-it/gallerysense/token.pickle")
INCOMING_CSV = Path(__file__).parent / "data/incoming_bonds.csv"
LOG_PATH     = Path(__file__).parent / "logs/bond_email_agent.log"
POLL_SECONDS = 600   # 10 min

GMAIL_QUERY  = 'label:bond-inventory is:unread'  # primary filter
DEALER_DOMAINS = [
    "raymondjames.com", "rwbaird.com", "pipersandler.com", "stifel.com",
    "bernardisecurities.com", "hjsims.com", "dadavidson.com",
    "hilliardlyons.com", "janney.com", "sperrycapital.com",
    "jbhanauer.com", "georgekmbaum.com", "bellwethercommunity.com",
    "loopcapital.com", "siebertwilliamsshank.com", "ramirezco.com",
    "opco.com", "brileyfin.com",
]

ANTHROPIC_CLIENT = anthropic.Anthropic()

CSV_HEADERS = [
    "cusip", "issuer", "state", "purpose", "issuer_type",
    "par_amount", "maturity_date", "coupon", "ytw", "ytm",
    "call_date", "call_price", "rating_moodys", "rating_sp", "rating_fitch",
    "last_trade_date", "last_trade_price", "is_target",
    "source_dealer", "extracted_at",
]

EXTRACT_PROMPT = """You are a municipal bond data extractor. You receive a dealer inventory email or "run sheet" containing municipal bond offerings.

Extract ALL municipal bonds mentioned. For each bond return a JSON object with these fields:
- cusip: 9-character CUSIP string (if present, else null)
- issuer: issuer name (city, county, authority, school district, etc.)
- state: 2-letter state abbreviation
- purpose: bond purpose (General Obligation, Water Revenue, School, Hospital Revenue, etc.)
- issuer_type: "GO" for general obligation, "Revenue" for revenue bonds, "Special Tax", etc.
- par_amount: face/par value in dollars as a number (e.g. 5000000)
- maturity_date: YYYY-MM-DD format
- coupon: coupon rate as a number (e.g. 4.5 for 4.500%)
- ytw: yield to worst as a number (e.g. 4.52)
- ytm: yield to maturity as a number (same as ytw if not specified)
- call_date: first call date YYYY-MM-DD or null
- call_price: call price (usually 100.0) or null
- rating_moodys: Moody's rating string (e.g. "A2") or null
- rating_sp: S&P rating string (e.g. "A+") or null
- rating_fitch: Fitch rating string or null
- last_trade_price: offered price or null

Return ONLY a JSON array of bond objects. If no bonds are found, return [].
Do not include commentary, markdown, or explanation."""


# ---------------------------------------------------------------------------
# Gmail helpers
# ---------------------------------------------------------------------------

def get_service():
    with open(TOKEN_PATH, "rb") as f:
        creds = pickle.load(f)
    if creds.expired and creds.refresh_token:
        from google.auth.transport.requests import Request
        creds.refresh(Request())
        with open(TOKEN_PATH, "wb") as f:
            pickle.dump(creds, f)
    return build("gmail", "v1", credentials=creds)


def get_unread_bond_emails(service, max_results=20):
    """Fetch unread emails from dealer domains (primary) + bond-inventory label."""
    seen: set[str] = set()
    msgs: list[dict] = []

    # Primary: all known dealer domains (split into two queries — Gmail OR limit)
    for chunk in [DEALER_DOMAINS[:6], DEALER_DOMAINS[6:]]:
        if not chunk:
            continue
        domain_q = " OR ".join(f"from:{d}" for d in chunk)
        r = service.users().messages().list(
            userId="me", q=f"is:unread ({domain_q})", maxResults=max_results
        ).execute()
        for m in r.get("messages", []):
            if m["id"] not in seen:
                seen.add(m["id"])
                msgs.append(m)

    # Secondary: bond-inventory label (catches manually-labeled emails)
    r2 = service.users().messages().list(
        userId="me", q=GMAIL_QUERY, maxResults=max_results
    ).execute()
    for m in r2.get("messages", []):
        if m["id"] not in seen:
            seen.add(m["id"])
            msgs.append(m)

    return msgs[:max_results]


def get_email_content(service, msg_id):
    msg = service.users().messages().get(userId="me", id=msg_id, format="full").execute()
    headers = {h["name"]: h["value"] for h in msg["payload"]["headers"]}

    def _decode_part(part):
        data = part.get("body", {}).get("data", "")
        if data:
            return base64.urlsafe_b64decode(data).decode("utf-8", errors="replace")
        return ""

    body = ""
    if "parts" in msg["payload"]:
        for part in msg["payload"]["parts"]:
            if part["mimeType"] == "text/plain":
                body = _decode_part(part)
                break
        if not body:
            for part in msg["payload"]["parts"]:
                if part["mimeType"] == "text/html":
                    raw = _decode_part(part)
                    body = re.sub(r"<[^>]+>", " ", raw)
                    body = re.sub(r"\s+", " ", body).strip()
                    break
    else:
        body = _decode_part(msg["payload"])

    return {
        "id": msg_id,
        "from": headers.get("From", ""),
        "subject": headers.get("Subject", ""),
        "date": headers.get("Date", ""),
        "body": body[:8000],  # Claude context limit guard
    }


def mark_as_read(service, msg_id):
    service.users().messages().modify(
        userId="me", id=msg_id, body={"removeLabelIds": ["UNREAD"]}
    ).execute()


# ---------------------------------------------------------------------------
# Detection
# ---------------------------------------------------------------------------

BOND_KEYWORDS = [
    "cusip", "yield", "maturity", "coupon", "bps", "basis points",
    "general obligation", "revenue bond", "muni", "municipal",
    "ytw", "ytm", "offering", "run sheet", "inventory", "available",
    "tax-exempt", "tax exempt", "GO bond", "fixed income",
]

def is_bond_inventory_email(email: dict) -> bool:
    """Heuristic check before spending an LLM call."""
    sender = email["from"].lower()
    if any(d in sender for d in DEALER_DOMAINS):
        return True
    text = (email["subject"] + " " + email["body"][:500]).lower()
    hits = sum(1 for kw in BOND_KEYWORDS if kw in text)
    return hits >= 3


# ---------------------------------------------------------------------------
# Extraction
# ---------------------------------------------------------------------------

def extract_bonds(email: dict) -> list[dict]:
    """Use Claude Haiku to extract structured bond data from email body."""
    content = f"From: {email['from']}\nSubject: {email['subject']}\n\n{email['body']}"

    try:
        resp = ANTHROPIC_CLIENT.messages.create(
            model="claude-haiku-4-5-20251001",
            max_tokens=2048,
            system=EXTRACT_PROMPT,
            messages=[{"role": "user", "content": content}],
        )
        raw = resp.content[0].text.strip()
        # Strip markdown fences if Haiku wraps output
        raw = re.sub(r"^```[a-z]*\n?", "", raw).rstrip("`").strip()
        return json.loads(raw)
    except json.JSONDecodeError:
        log(f"  [parse error] could not parse JSON from extraction")
        return []
    except Exception as exc:
        log(f"  [extract error] {exc}")
        return []


# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

def _extract_dealer(sender: str) -> str:
    match = re.search(r"@([\w.]+)>?$", sender)
    domain = match.group(1) if match else sender
    return domain.split(".")[0].title()


def _existing_cusips() -> set[str]:
    """Return set of CUSIPs already in incoming_bonds.csv."""
    if not INCOMING_CSV.exists():
        return set()
    with open(INCOMING_CSV, newline="") as f:
        return {row.get("cusip", "").strip() for row in csv.DictReader(f)}


def append_to_csv(bonds: list[dict], dealer: str, dry_run: bool = False) -> int:
    """Write extracted bonds to incoming_bonds.csv. Returns count written."""
    if not bonds:
        return 0

    INCOMING_CSV.parent.mkdir(exist_ok=True)
    new_file = not INCOMING_CSV.exists()
    today = date.today().isoformat()
    written = 0

    if dry_run:
        for b in bonds:
            log(f"  [dry-run] {b.get('cusip','?')} {b.get('issuer','?')[:40]} "
                f"ytw={b.get('ytw','?')} mat={b.get('maturity_date','?')}")
        return len(bonds)

    seen = _existing_cusips()

    with open(INCOMING_CSV, "a", newline="") as f:
        w = csv.DictWriter(f, fieldnames=CSV_HEADERS, extrasaction="ignore")
        if new_file:
            w.writeheader()
        for b in bonds:
            if not b.get("ytw") or not b.get("issuer"):
                continue
            cusip = b.get("cusip") or ""
            if cusip and cusip in seen:
                log(f"  ⊘ {cusip} already in CSV — skipped (duplicate)")
                continue
            if cusip:
                seen.add(cusip)
            row = {
                "cusip":          b.get("cusip") or f"UNKNOWN-{written}",
                "issuer":         b.get("issuer", ""),
                "state":          b.get("state", ""),
                "purpose":        b.get("purpose", ""),
                "issuer_type":    b.get("issuer_type", "Revenue"),
                "par_amount":     b.get("par_amount") or 0,
                "maturity_date":  b.get("maturity_date", ""),
                "coupon":         b.get("coupon") or 0,
                "ytw":            b.get("ytw") or 0,
                "ytm":            b.get("ytm") or b.get("ytw") or 0,
                "call_date":      b.get("call_date") or "",
                "call_price":     b.get("call_price") or "",
                "rating_moodys":  b.get("rating_moodys") or "",
                "rating_sp":      b.get("rating_sp") or "",
                "rating_fitch":   b.get("rating_fitch") or "",
                "last_trade_date": today,
                "last_trade_price": b.get("last_trade_price") or "",
                "is_target":      "true",
                "source_dealer":  dealer,
                "extracted_at":   datetime.now().isoformat(timespec="seconds"),
            }
            w.writerow(row)
            written += 1

    return written


# ---------------------------------------------------------------------------
# Trigger scanner
# ---------------------------------------------------------------------------

def run_scanner_if_new_bonds(n_new: int):
    """Auto-trigger bond_scanner when fresh bonds arrive."""
    if n_new == 0:
        return
    log(f"  🔍 Triggering scanner on {INCOMING_CSV.name}...")
    import subprocess
    result = subprocess.run(
        ["python3", "bond_scanner.py", "--csv", str(INCOMING_CSV),
         "--output", "output/latest_alerts.json"],
        capture_output=True, text=True, cwd=Path(__file__).parent,
    )
    if result.returncode == 0:
        alerts_path = Path(__file__).parent / "output/latest_alerts.json"
        try:
            alerts = json.loads(alerts_path.read_text())
            log(f"  📊 Scanner: {len(alerts)} alert(s) from {n_new} new bond(s)")
            if alerts:
                _email_alerts(alerts)
        except Exception:
            log(f"  📊 Scanner complete")
    else:
        log(f"  ⚠️  Scanner error: {result.stderr[:200]}")


def _research_issuer(issuer: str, state: str, purpose: str) -> str:
    key = os.getenv("PERPLEXITY_API_KEY", "")
    if not key:
        return ""
    query = f"{issuer} {state} {purpose} bond credit outlook 2026"
    try:
        resp = requests.post(
            "https://api.perplexity.ai/chat/completions",
            headers={"Authorization": f"Bearer {key}"},
            json={
                "model": "sonar",
                "messages": [{"role": "user", "content": query}],
                "max_tokens": 250,
            },
            timeout=15,
        )
        resp.raise_for_status()
        return resp.json()["choices"][0]["message"]["content"].strip()
    except Exception as exc:
        log(f"  [perplexity] {exc}")
        return ""


def _email_alerts(alerts: list[dict]):
    """Send alert digest to olivierboukli@gmail.com."""
    import base64
    from email.mime.text import MIMEText

    lines = [f"MUNI SCANNER — {len(alerts)} ALERT(S)\n"]
    for a in alerts:
        cusip = a['cusip']
        emma_url  = f"https://emma.msrb.org/Security/Details/{cusip}"
        trade_url = f"https://emma.msrb.org/Security/Details/{cusip}#tradeHistory"
        log(f"  🔎 Researching {a['issuer']}...")
        research = _research_issuer(a['issuer'], a['state'], a['purpose'])
        lines.append(
            f"{'='*62}\n"
            f"  {a['alert_id']}  {'[PUBLIC]' if a.get('is_public') else ''}\n"
            f"  {a['issuer']}  |  {a['state']}  |  {cusip}\n"
            f"  YTW: {a['ytw']}%   Peer avg: {a['peer_avg_ytw']}%   "
            f"Spread: +{a['spread_bps']}bps\n"
            f"  Rating: {a['rating']}   Maturity: {a['maturity_date']}\n"
            f"  Par: ${a['par_amount']/1e6:.1f}M\n"
            f"\n{a['plain_english']}\n"
        )
        if research:
            lines.append(f"\n  WEB INTELLIGENCE:\n{research}\n")
        if a.get("red_flag"):
            lines.append(f"\n  ⚠️  {a['red_flag']}\n")
        lines.append(
            f"\n  VERIFY BEFORE BUYING:\n"
            f"  EMMA:   {emma_url}\n"
            f"  Trades: {trade_url}\n"
        )

    subject = f"Muni Alert: {len(alerts)} bond(s) — {date.today().isoformat()}"
    body    = "\n".join(lines)

    try:
        service = get_service()
        msg = MIMEText(body)
        msg["to"]      = "olivierboukli@gmail.com"
        msg["subject"] = subject
        raw = base64.urlsafe_b64encode(msg.as_bytes()).decode()
        service.users().messages().send(userId="me", body={"raw": raw}).execute()
        log(f"  📧 Alert email sent ({len(alerts)} alert(s))")
    except Exception as exc:
        log(f"  ⚠️  Alert email failed: {exc}")


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def log(msg: str):
    ts = datetime.now().strftime("%H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line)
    try:
        LOG_PATH.parent.mkdir(exist_ok=True)
        with open(LOG_PATH, "a") as f:
            f.write(line + "\n")
    except Exception:
        pass


# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def run_agent(dry_run: bool = False):
    log("Bond Email Agent — scanning...")
    service = get_service()
    emails  = get_unread_bond_emails(service)

    if not emails:
        log("No unread bond emails.")
        return 0

    total_bonds = 0
    for e in emails:
        email = get_email_content(service, e["id"])
        log(f"Checking: {email['subject'][:60]}  from {email['from'][:40]}")

        if not is_bond_inventory_email(email):
            mark_as_read(service, email["id"])
            log("  Skipped (not a bond inventory email)")
            continue

        bonds  = extract_bonds(email)
        dealer = _extract_dealer(email["from"])
        log(f"  {dealer}: extracted {len(bonds)} bond(s)")

        # Quick Perplexity check on the highest-yield bond before writing to CSV
        if bonds:
            top = max(bonds, key=lambda b: b.get("ytw") or 0)
            if top.get("ytw") and top["ytw"] > 4.0 and top.get("issuer"):
                intel = _research_issuer(
                    top.get("issuer", ""), top.get("state", ""), top.get("purpose", "")
                )
                if intel:
                    log(f"  🔎 {top['issuer'][:40]}: {intel[:120]}...")

        n = append_to_csv(bonds, dealer, dry_run=dry_run)
        total_bonds += n
        if n:
            log(f"  ✅ {n} bond(s) written to {INCOMING_CSV.name}")

        if not dry_run:
            mark_as_read(service, email["id"])

    run_scanner_if_new_bonds(total_bonds)
    return total_bonds


def run_loop(dry_run: bool = False):
    log(f"Bond Email Agent — polling every {POLL_SECONDS}s")
    while True:
        try:
            run_agent(dry_run=dry_run)
        except KeyboardInterrupt:
            log("Stopped.")
            sys.exit(0)
        except Exception as exc:
            log(f"[error] {exc}")
        time.sleep(POLL_SECONDS)


if __name__ == "__main__":
    dry_run = "--dry-run" in sys.argv
    loop    = "--loop"    in sys.argv
    if loop:
        run_loop(dry_run=dry_run)
    else:
        run_agent(dry_run=dry_run)
