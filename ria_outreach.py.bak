"""
RIA Outreach — send muni alert sample to boutique fixed-income prospects.

Usage:
    python3 ria_outreach.py --dry-run      # print emails, don't send
    python3 ria_outreach.py                # send to all with contact_email set
    python3 ria_outreach.py --firm "Cumberland Advisors"
"""

import base64
import csv
import json
import os
import pickle
import sys
from datetime import datetime, timezone
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from pathlib import Path

from dotenv import load_dotenv
load_dotenv(Path(__file__).parent / ".env")

TOKEN_PATH  = Path.home() / "gallerysense/token.pickle"
ALERTS_PATH = Path(__file__).parent / "output/latest_alerts.json"
PROSPECT_CSV = Path(__file__).parent / "prospects.csv"
SENDER_NAME  = "Olivier Boukli"
REPLY_TO     = os.getenv("REPORT_EMAIL", "olivierboukli@gmail.com")
DRY_RUN      = "--dry-run" in sys.argv
FIRM_FILTER  = None
for i, a in enumerate(sys.argv):
    if a == "--firm" and i + 1 < len(sys.argv):
        FIRM_FILTER = sys.argv[i + 1]


# ---------------------------------------------------------------------------
# Email body
# ---------------------------------------------------------------------------

EMAIL_SUBJECT = "BondAnomaly: free sample alert we flagged this morning (+127 bps)"

EMAIL_BODY = """\
Hi {name},

I run an automated muni bond anomaly scanner that monitors dealer flow for \
yield spreads that stand out versus A-rated peers in the same maturity bucket. \
This morning it flagged one I thought was worth sharing:

──────────────────────────────────────────────
ALERT: Jefferson Parish, LA — Hospital Revenue
──────────────────────────────────────────────
CUSIP:      452151RK8
Maturity:   2035-12-01
Rating:     A2 / A
Par:        $12,400,000
Yield:      5.41% YTW
Peer avg:   4.14% YTW
Spread:     +127 bps vs rated peers

Call risk:  Moderate — callable ~2029 at par. Monitor refi conditions.

Why it's interesting: At 127 bps over comparable A-rated hospital revenue
paper in the same maturity range, this is either a liquidity story (small
issuer, thin secondary) or a credit story (Jefferson Parish budget pressures
post-Katrina rebuild). Either way, worth a look for a tax-exempt income
mandate that can tolerate the illiquidity premium.

EMMA link: https://emma.msrb.org/Security/Details/452151RK8
──────────────────────────────────────────────

We see 5-15 alerts like this per week across revenue bonds, GOs, and
pre-refunded paper — filtered from 18 dealer feeds.

I'm offering early access at $299/month:
  • Weekly alert digest every Monday morning
  • Each alert: yield spread, peer benchmark, call analysis, EMMA link,
    and a 2-paragraph credit summary via live AI research
  • Covers any state, any sector, any rating tier you specify

No long contract — cancel anytime. If the first month doesn't pay for
itself in one idea, I'll refund it.

Subscribe directly: https://buy.stripe.com/14AbIT3Vv08F7fWf13bEA00
More info: https://bondanomaly.com

Worth a 15-minute call this week?

{sender}
{reply_to}
+1 (786) 716-8785
"""


# ---------------------------------------------------------------------------
# Gmail
# ---------------------------------------------------------------------------

def _gmail_service():
    with open(TOKEN_PATH, "rb") as f:
        creds = pickle.load(f)
    if creds.expired and creds.refresh_token:
        from google.auth.transport.requests import Request
        creds.refresh(Request())
        with open(TOKEN_PATH, "wb") as f:
            pickle.dump(creds, f)
    from googleapiclient.discovery import build
    return build("gmail", "v1", credentials=creds)


def _send(service, to: str, subject: str, body: str):
    msg = MIMEMultipart()
    msg["to"]       = to
    msg["subject"]  = subject
    msg["Reply-To"] = REPLY_TO
    msg.attach(MIMEText(body, "plain"))
    raw = base64.urlsafe_b64encode(msg.as_bytes()).decode()
    service.users().messages().send(userId="me", body={"raw": raw}).execute()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

SEND_LOG = Path(__file__).parent / "outreach_log.csv"

def _log_send(email: str, firm: str, name: str):
    exists = SEND_LOG.exists()
    with open(SEND_LOG, "a") as f:
        if not exists:
            f.write("email,firm,name,sent_at,nudge_sent\n")
        f.write(f"{email},{firm},{name},{datetime.now(timezone.utc).isoformat()},\n")


def _already_sent() -> set:
    """Return set of email addresses already present in outreach_log.csv."""
    if not SEND_LOG.exists():
        return set()
    seen = set()
    with open(SEND_LOG) as f:
        reader = csv.DictReader(f)
        for row in reader:
            addr = (row.get("email") or "").strip().lower()
            if addr:
                seen.add(addr)
    return seen


def main():
    service = None if DRY_RUN else _gmail_service()
    sent = skipped = dup = 0
    already = _already_sent()

    with open(PROSPECT_CSV) as f:
        prospects = list(csv.DictReader(f))

    for p in prospects:
        firm  = p.get("firm", "").strip()
        email = p.get("contact_email", "").strip()
        name  = p.get("contact_name", "").strip() or "there"
        focus = p.get("focus", "")

        if FIRM_FILTER and firm.lower() != FIRM_FILTER.lower():
            continue

        if not email:
            print(f"  [SKIP] {firm} — no email on file")
            skipped += 1
            continue

        if email.lower() in already:
            print(f"  [DUP]  {firm} <{email}> — already in outreach_log.csv, skipping")
            dup += 1
            continue

        body = EMAIL_BODY.format(
            name=name.split()[0] if name != "there" else "there",
            sender=SENDER_NAME,
            reply_to=REPLY_TO,
        )

        if DRY_RUN:
            print(f"\n{'='*60}")
            print(f"TO:      {name} <{email}>  ({firm})")
            print(f"SUBJECT: {EMAIL_SUBJECT}")
            print(body[:400] + "...")
        else:
            _send(service, email, EMAIL_SUBJECT, body)
            print(f"  → Sent to {name} <{email}> ({firm})")

        # Log send for follow-up tracking
        _log_send(email, firm, name)
        already.add(email.lower())
        sent += 1

    print(f"\nSent: {sent}  Skipped (no email): {skipped}  Duplicates skipped: {dup}")
    if skipped:
        print("→ Fill in contact_email in prospects.csv for skipped firms.")
        print("  Find contacts: LinkedIn → firm name → 'Portfolio Manager' or 'Director Fixed Income'")


if __name__ == "__main__":
    main()
